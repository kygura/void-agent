{
	"name": "@void/orchestrator",
	"version": "0.65.2",
	"description": "Headless, provider-agnostic child orchestration",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./providers/mock": {
			"types": "./dist/providers/mock.d.ts",
			"import": "./dist/providers/mock.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"test": "bun test",
		"prepublishOnly": "bun run clean && bun run build"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"typescript": "^5.9.2"
	}
}
